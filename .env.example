# Resend API key (get one at https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Your email address to receive RSVP notifications
HOST_EMAIL=your@email.com

# Google Sheets API credentials
# 1. Go to https://console.cloud.google.com
# 2. Create a project and enable the Google Sheets API
# 3. Create a service account and download the JSON key
# 4. Copy the client_email and private_key from the JSON

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID of your Google Sheet (from the URL)
# https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
# Make sure to share the sheet with your service account email!
GOOGLE_SHEET_ID=your_sheet_id_here

# Optional: Base URL for edit links (auto-detected in most cases)
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
